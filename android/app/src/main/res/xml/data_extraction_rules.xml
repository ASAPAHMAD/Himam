<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup/transfer rules.

  Excludes the WebView's Local Storage and IndexedDB directories, which is
  where the Capacitor WebView persists the Supabase auth session (access +
  refresh tokens) via `persistSession: true` (see src/lib/supabase.ts).
  Without this exclusion, a live session could be carried over via Google's
  cloud backup or a device-to-device transfer.

  Everything else the app stores remains eligible for backup/transfer as
  before — this only narrows out the WebView session data.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="app_webview/Local Storage" />
        <exclude domain="root" path="app_webview/IndexedDB" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="app_webview/Local Storage" />
        <exclude domain="root" path="app_webview/IndexedDB" />
    </device-transfer>
</data-extraction-rules>
